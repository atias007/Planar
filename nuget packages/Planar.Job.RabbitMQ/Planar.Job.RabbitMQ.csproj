<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>netstandard2.0;netstandard2.1</TargetFrameworks>
		<Version>1.8.1.0</Version>
		<RepositoryType>git</RepositoryType>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
		<Description>Library for writing .NET jobs for Planar, Triggered by RabbitMQ queue</Description>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<PackageIcon>nuget_logo.png</PackageIcon>
		<Title>Library for writing .NET jobs for Planar, Triggered by RabbitMQ queue</Title>
		<PackageProjectUrl>https://github.com/atias007/Planar</PackageProjectUrl>
		<RepositoryUrl>https://github.com/atias007/Planar</RepositoryUrl>
		<PackageTags>planar;job;schedule;task;automation</PackageTags>
		<IncludeSymbols>False</IncludeSymbols>
	</PropertyGroup>
	<PropertyGroup Condition=" '$(TargetFramework)' != 'netstandard2.0'">
		<Nullable>enable</Nullable>
	</PropertyGroup>
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
		<NoWarn>1701;1702;NU1803</NoWarn>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
		<NoWarn>1701;1702;NU1803</NoWarn>
	</PropertyGroup>
	<ItemGroup>
		<None Include="..\..\res\nuget_logo.png">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
